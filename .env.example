PORT=3000
RELAY_CSV_URL=https://raw.githubusercontent.com/permissionlesstech/bitchat/main/relays/online_relays_gps.csv

# optional history api (npm run api) - see README
API_PORT=3001
# API_DB=api/glub-history.db
# API_BUFFER_MAX=2000   # rolling buffer size (max events kept; oldest pruned)

# ephemeral media uploads (assist-only "+" button). urls shared into chat are
# absolute, so set the public origin your users reach the site at:
# API_PUBLIC_ORIGIN=https://glub.chat
# API_MEDIA_MAX_BYTES=10485760   # max upload size (10mb)
# API_MEDIA_MAX_ITEMS=50         # max stored items before oldest are pruned
# API_MEDIA_DIR=api/media-tmp    # wiped on api restart

# when API_PORT (or API_ORIGIN) is set, the static server transparently proxies
# /api -> the api, so the client reaches it same-origin (no CORS, no client
# config). Set API_ORIGIN only if the api runs on a different host:
# API_ORIGIN=http://127.0.0.1:3001
