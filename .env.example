PORT=3000
RELAY_CSV_URL=https://raw.githubusercontent.com/permissionlesstech/bitchat/main/relays/online_relays_gps.csv

# optional history api (npm run api) - see README
API_PORT=3001
# API_DB=api/glub-history.db
# API_BUFFER_MAX=2000   # rolling buffer size (max events kept; oldest pruned)

# ephemeral media uploads (assist-only "+" button). shared media links are
# absolutized by the client against its own (https) origin, so nothing to set for
# a normal same-origin deploy. only set API_PUBLIC_ORIGIN to serve media from a
# DIFFERENT origin (e.g. a dedicated media host/cdn):
# API_PUBLIC_ORIGIN=https://media.glub.chat
# API_MEDIA_MAX_BYTES=10485760   # max upload size (10mb)
# API_MEDIA_MAX_ITEMS=50         # max stored items before oldest are pruned
# API_MEDIA_DIR=api/media-tmp    # wiped on api restart

# optional message translation (assist-only "translate" action in the tap menu).
# defaults to DeepL's free tier; the key stays server-side. leave unset to
# disable translation entirely (the client hides the action).
# TRANSLATE_API_KEY=your-deepl-auth-key
# TRANSLATE_API_URL=https://api-free.deepl.com/v2/translate   # use api.deepl.com for Pro
# TRANSLATE_AUTH_SCHEME=DeepL-Auth-Key                        # e.g. "Bearer" for other providers

# when API_PORT (or API_ORIGIN) is set, the static server transparently proxies
# /api -> the api, so the client reaches it same-origin (no CORS, no client
# config). Set API_ORIGIN only if the api runs on a different host:
# API_ORIGIN=http://127.0.0.1:3001
